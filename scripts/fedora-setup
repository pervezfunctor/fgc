#!/usr/bin/env bash

set -Eeuo pipefail

# trap 'echo "Error on line $LINENO: $BASH_COMMAND"' ERR
trap 'echo "ERROR rc=$? line=$LINENO cmd=$BASH_COMMAND" >&2' ERR

readonly REPO_NAME="fedora-config"
readonly DOT_DIR="$HOME/.${REPO_NAME}"

readonly COMMON_PACKAGES=(
  fish
  bat
  duf
  fd
  gdu
  fzf
  gh
  htop
  rclone
  ripgrep
  rsync
  tmux
  jq
  tealdeer
  trash-cli
  ugrep
  yq
  shellcheck
  difftastic
  zoxide
  eza
)

log() {
  printf "\033[1;34m🚀 %s\033[0m\n" "$*"
}

error() {
  printf "\033[1;31m🔥 %s\033[0m\n" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

pixi_install() {
  if has_cmd pixi; then
    return 0
  fi
  has_cmd curl || die "curl is not installed. Quitting."

  log "Installing pixi."
  curl -fsSL https://pixi.sh/install.sh | sh

  has_cmd pixi || die "Failed to install pixi"
  log "pixi installation done!"
}

fish_install() {
  log "Configuring fish shell..."

  log "Trashing existing config.fish...(use trash-restore to restore)"
  has_cmd trash || die "trash not installed."
  trash ~/.config/fish/config.fish || true

  log "Linking ($DOT_DIR/fish/config.fish) -> ($HOME/.config/fish/config.fish)"
  mkdir -p "$HOME/.config/fish"
  ln -sf "${DOT_DIR}/fish/config.fish" "${HOME}/.config/fish/config.fish"

  log "Adding fish to /etc/shells if not present..."
  local fish_path
  if ! fish_path="$(command -v fish)"; then
    die "fish executable not found"
  fi

  if ! grep -qxF "$fish_path" /etc/shells 2>/dev/null; then
    echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
  fi

  log "Setting fish as default shell..."
  if sudo chsh -s "$fish_path" "$USER"; then
    log "Successfully set fish as default shell"
  else
    log "Failed to set fish as default shell"
    log "Run 'sudo chsh -s $(which fish) $USER' to set it manually"
  fi
}

dotfiles_install() {
  if [ ! -d "$DOT_DIR" ]; then
    has_cmd git || die "git is not installed. Quitting."
    log "Cloning dotfiles..."
    git clone https://github.com/pervezfunctor/fedora-config "$DOT_DIR" || die "git clone failed"
    log "dotfiles installation done!"
  fi
}

system_install() {
  log "Updating system packages..."
  sudo dnf update --refresh -y

  log "Installing system dependencies..."
  sudo dnf install -y git which curl wget tar gcc less libatomic make pipx plocate shfmt unzip zstd "${COMMON_PACKAGES[@]}"

  tldr --update || true
  sudo updatedb || true
  log "system installation done!"
}

packages_install() {
  log "Installing pixi packages..."
  pixi global install nushell starship carapace
  if has_cmd rpm-ostree; then
    pixi global install go-shfmt "${COMMON_PACKAGES[@]}"
  fi
  log "packages installation done!"
}

help() {
  local name
  name="$(basename "$0")"
  printf "\033[1;34m🚀 Usage: %s [command]...\033[0m\n" "$name"
  printf "\033[1;34m🚀\033[0m\n"
  printf "\033[1;34m🚀 Commands:\033[0m\n"
  printf "\033[1;34m🚀   system    - Install system dependencies\033[0m\n"
  printf "\033[1;34m🚀   pixi      - Install pixi\033[0m\n"
  printf "\033[1;34m🚀   dotfiles  - Clone dotfiles\033[0m\n"
  printf "\033[1;34m🚀   fish      - Install fish shell\033[0m\n"
  printf "\033[1;34m🚀\033[0m\n"
}

main() {
  export PATH="/home/linuxbrew/.linuxbrew/bin:$HOME/.pixi/bin:$PATH"

  if (($# > 0)); then
    case "$1" in
    help | --help | -h)
      help
      return
      ;;
    esac

    for arg in "$@"; do
      if ! "${arg}_install"; then
        die "Failed: ${arg} install"
      fi
    done
    return
  fi

  log "Fedora Config Setup..."

  if has_cmd dnf; then
    system_install
  fi
  dotfiles_install
  pixi_install
  packages_install
  fish_install

  log "╔══════════════════════════════════════╗"
  log "║   Fedora Configuration complete.     ║"
  log "║   Use setup.nu for further config.   ║"
  log "╚══════════════════════════════════════╝"
}

main "$@"
