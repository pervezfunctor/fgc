#!/bin/sh

set -eu

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

readonly REPO_URL="https://github.com/pervezfunctor/fedora-config.git"
readonly DOT_DIR="$HOME/.fedora-config"

log() {
  printf "INFO: %s\n" "$*"
  printf "INFO: %s\n" "$*" >>"${HOME}/.fedora-config.log"
}

warn() {
  printf "WARNING: %s\n" "$*"
  printf "WARNING: %s\n" "$*" >>"${HOME}/.fedora-config.log"
}

die() {
  printf "ERROR: %s\n" "$*" >&2
  printf "ERROR: %s\n" "$*" >>"${HOME}/.fedora-config.log"
  exit 1
}

dotfiles_install() {
  has_cmd git || die "git not found. Quitting."

  if [ ! -d "$DOT_DIR" ]; then
    log "Cloning dotfiles to $DOT_DIR."
    git clone "$REPO_URL" "$DOT_DIR" || die "Failed to clone $REPO_URL"
    return
  elif [ -z "$(git -C "$DOT_DIR" status --porcelain)" ]; then
    log "Dotfiles repo clean. Pulling latest changes"
    git -C "$DOT_DIR" pull --rebase || {
      warn "Rebase failed. Aborting."
      git -C "$DOT_DIR" rebase --abort || die "Failed to abort rebase"
    }
  else
    warn "Dotfiles repo dirty. Skipping update."
    return
  fi
}

system_install() {
  sudo dnf update -y || die "Failed to update packages"

  sudo dnf install -y git gcc pipx libatomic make plocate tar tmux unzip \
    zstd bat direnv duf eza fd fzf gdu gh jq ripgrep tealdeer trash-cli \
    zoxide difftastic less htop gum tmux cmake

  tldr --update || die "Failed to install dependencies"

  sudo updatedb
}

pixi_install() {
  has_cmd pixi && return 0

  has_cmd curl || die "curl is not installed. Quitting."
  log "Installing pixi."
  curl -fsSL https://pixi.sh/install.sh | sh
  has_cmd pixi || die "Failed to install pixi"
}

pixi_packages_install() {
  pixi global install carapace nushell xh television starship bottom
}

is_fish_in_bash() {
  grep -q 'exec fish' ~/.bashrc 2>/dev/null
}

launch_fish_in_bash_install() {
  is_fish_in_bash || cat <<'EOF' >>~/.bashrc

# Auto-start fish for interactive shells
if [[ $- == *i* ]] && [[ -z "$FISH_LAUNCHED" ]]; then
  export PATH="/opt/homebrew/bin:$PATH"
  if command -v fish >/dev/null 2>&1; then
    export FISH_LAUNCHED=1
    exec fish || echo "Failed to start fish, staying in bash"
  fi
fi

EOF
}

fish_config() {
  has_cmd fish || die "fish not installed. Quitting."
  if [ -L ~/.config/fish/config.fish ] &&
    [ "$(readlink ~/.config/fish/config.fish)" = "${DOT_DIR}/fish/config.fish" ]; then
    return 0
  fi

  mkdir -p ~/.config/fish 2>/dev/null
  if [ -f ~/.config/fish/config.fish ]; then
    log "Trashing existing fish config..."
    trash ~/.config/fish/config.fish
  fi
  ln -sf "${DOT_DIR}/fish/config.fish" ~/.config/fish/config.fish

  launch_fish_in_bash_install
}

fresh_install() {
  has_cmd dnf && system_install
  dotfiles_install

  pixi_install
  pixi_packages_install

  fish_config
  has_cmd nu || die "nu is not installed. Quitting."
}

has_commands() {
  for cmd in "$@"; do
    has_cmd "$cmd" || return 1
  done
  return 0
}

init_log() {
  echo "Initializing log..."
  rm -f "${HOME}/.mac-setup.log" 2>/dev/null
  touch "${HOME}/.mac-setup.log"
}

main() {
  export PATH="/home/linuxbrew/.linuxbrew/bin:$HOME/.pixi/bin:$PATH"
  init_log

  if is_fish_in_bash && has_commands git pixi fish nu trash starship gum; then
    log "All commands found, skipping fresh install. Use '${DOT_DIR}/scripts/setup.nu' to configure your system"
  else
    fresh_install
  fi
}

main "$@"
