#!/usr/bin/env bash

set -Eeuo pipefail

readonly REPO_NAME="fedora-config"
readonly DOT_DIR="$HOME/.${REPO_NAME}"

log() {
  printf "\033[1;34mℹ\033[0m %s\n" "$*"
}

error() {
  printf "\033[1;31m✖\033[0m %s\n" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

pixi_install() {
  export PATH="$HOME/.pixi/bin:$PATH"
  has_cmd pixi && return 0
  has_cmd curl || die "curl is not installed. Quitting."

  log "Installing pixi."
  curl -fsSL https://pixi.sh/install.sh | sh
  has_cmd pixi || die "Failed to install pixi"

  log "Installing pixi packages..."
  pixi global install nushell starship
}

fish_config() {
  log "Configuring fish shell..."

  log "Trashing existing config.fish...(use trash-restore to restore)"
  trash ~/.config/fish/config.fish

  log "Linking new config.fish..."
  ln -sf "$DOT_DIR/fish/config.fish" ~/.config/fish/config.fish

  log "Setting fish as default shell..."
  sudo chsh -s "$(which fish)" "$USER"
}

dotfiles_clone() {
  has_cmd git || die "git is not installed. Quitting."

  if [ ! -d "$DOT_DIR" ]; then
    log "Cloning dotfiles..."
    git clone https://github.com/pervezfunctor/fedora-config "$DOT_DIR" || die "git clone failed"
  fi
  [ -d "$DOT_DIR" ] || die "$DOT_DIR directory not found. Quitting."
}

system_install() {
  log "Updating system packages..."
  sudo dnf update -y

  log "Installing system dependencies..."
  sudo dnf install -y git which less curl fish
}
main() {
  log "Fedora Config Setup..."

  has_cmd dnf && system_install
  pixi_install
  fish_config
  dotfiles_clone

  echo ""
  log "Shell configuration complete."
  log "Use ~/.fedora-config/scripts/setup.nu for further setup."
  echo ""
}

main "$@"
