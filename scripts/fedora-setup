#!/usr/bin/env bash

set -Eeuo pipefail

readonly REPO_NAME="fedora-config"
readonly DOT_DIR="$HOME/.${REPO_NAME}"

log() {
  printf "\033[1;34mℹ\033[0m %s\n" "$*"
}

error() {
  printf "\033[1;31m✖\033[0m %s\n" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

main() {
  has_cmd dnf || die "Only Fedora is supported. Quitting."

  if [ ! -d "$DOT_DIR" ]; then
    git clone https://github.com/pervezfunctor/fedora-config "$DOT_DIR" || die "git clone failed"
  fi

  sudo dnf update -y
  sudo dnf install -y nix nix-daemon
  sudo systemctl enable --now nix-daemon

  has_cmd nix || die "nix is not installed. Quitting."

  nix run nixpkgs#nu -- "$DOT_DIR"/scripts/setup.nu shell || die "shell/fish setup failed"

  echo ""
  log "Shell configuration complete."
  log "Use nix run nixpkgs#nu -- ~/.fedora-config/scripts/setup.nu for further setup."
  echo ""
}
